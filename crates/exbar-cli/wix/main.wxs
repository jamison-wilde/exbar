<?xml version='1.0' encoding='utf-8'?>
<!--
  Exbar MSI installer.
  Build with: wix build -arch x64 -d Version=0.1.0 -d CargoTargetBinDir=target/release \
               crates/exbar-cli/wix/main.wxs -o target/wix/exbar-0.1.0-x64.msi \
               -ext WixToolset.Util.wixext
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <Package
        Name="Exbar"
        Version="$(Version)"
        Manufacturer="Exbar"
        UpgradeCode="E47632D3-B73C-4EE3-B987-D2E04332BCDB"
        Language="1033"
        Compressed="yes"
        Scope="perUser"
        InstallerVersion="500">

        <SummaryInformation Description="Exbar — floating folder-shortcut toolbar for Windows 11 File Explorer" />

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit." />

        <MediaTemplate EmbedCab="yes" />

        <!-- Shut down any running exbar.exe before replacing files -->
        <util:CloseApplication Id="CloseExbar"
                               Target="exbar.exe"
                               CloseMessage="yes"
                               TerminateProcess="500"
                               RebootPrompt="no" />

        <Feature Id="Main" Title="Exbar" Level="1">
            <ComponentRef Id="ExbarExe" />
            <ComponentRef Id="RunKey" />
            <ComponentRef Id="UninstallEntry" />
            <ComponentRef Id="StartMenuShortcut" />
        </Feature>

        <!-- UI: WixUI_Minimal = Welcome/License → Finish. Finish dialog has
             a "Launch Exbar now" checkbox wired to WixShellExec. ShellExecute
             does NOT inherit msiexec's STARTUPINFO / console pipe, so Windows
             Terminal doesn't claim a phantom tab the way an ExeCommand-type
             deferred CustomAction would. -->
        <ui:WixUI Id="WixUI_Minimal" />
        <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Exbar now" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

        <!-- ShellExecute target — [#FileId] resolves to installed exe path.
             WixShellExec passes no arguments, so the CLI treats no-args as
             the `hook` subcommand (see main.rs). -->
        <Property Id="WixShellExecTarget" Value="[#ExbarExeFile]" />

        <CustomAction Id="LaunchApplication"
                      BinaryRef="Wix4UtilCA_X64"
                      DllEntry="WixShellExec"
                      Impersonate="yes"
                      Execute="immediate"
                      Return="check" />

        <UI>
            <Publish Dialog="ExitDialog"
                     Control="Finish"
                     Event="DoAction"
                     Value="LaunchApplication"
                     Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
        </UI>

        <StandardDirectory Id="LocalAppDataFolder">
            <Directory Id="INSTALLDIR" Name="Exbar" />
        </StandardDirectory>

        <!-- Start Menu shortcut so users can re-launch the toolbar after killing it -->
        <StandardDirectory Id="ProgramMenuFolder" />

        <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder" Guid="*" Bitness="always64">
            <Shortcut Id="ExbarShortcut"
                      Name="Exbar"
                      Description="Floating folder-shortcut toolbar for File Explorer"
                      Target="[INSTALLDIR]exbar.exe"
                      Arguments="hook"
                      WorkingDirectory="INSTALLDIR" />
            <RegistryValue
                Root="HKCU"
                Key="Software\Exbar"
                Name="ShortcutInstalled"
                Type="integer"
                Value="1"
                KeyPath="yes" />
        </Component>

        <!-- exbar.exe component -->
        <Component Id="ExbarExe" Directory="INSTALLDIR" Guid="*" Bitness="always64">
            <File Id="ExbarExeFile"
                  Source="$(CargoTargetBinDir)\exbar.exe"
                  KeyPath="yes" />
        </Component>

        <!-- Run key: auto-start hook at login -->
        <Component Id="RunKey" Directory="INSTALLDIR" Guid="*" Bitness="always64">
            <RegistryValue
                Root="HKCU"
                Key="Software\Microsoft\Windows\CurrentVersion\Run"
                Name="Exbar"
                Type="string"
                Value="&quot;[INSTALLDIR]exbar.exe&quot; hook"
                KeyPath="yes" />
        </Component>

        <!-- Uninstall metadata — shown in Settings → Apps -->
        <Component Id="UninstallEntry" Directory="INSTALLDIR" Guid="*" Bitness="always64">
            <RegistryKey Root="HKCU" Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\Exbar">
                <RegistryValue Name="DisplayName" Type="string" Value="Exbar" />
                <RegistryValue Name="DisplayVersion" Type="string" Value="$(Version)" />
                <RegistryValue Name="Publisher" Type="string" Value="Exbar" />
                <RegistryValue Name="InstallLocation" Type="string" Value="[INSTALLDIR]" />
                <RegistryValue Name="UninstallString" Type="string" Value="msiexec /x [ProductCode]" />
                <RegistryValue Name="NoModify" Type="integer" Value="1" />
                <RegistryValue Name="NoRepair" Type="integer" Value="1" />
            </RegistryKey>
            <RegistryValue
                Root="HKCU"
                Key="Software\Microsoft\Windows\CurrentVersion\Uninstall\Exbar"
                Name="Installed"
                Type="integer"
                Value="1"
                KeyPath="yes" />
        </Component>

    </Package>
</Wix>
